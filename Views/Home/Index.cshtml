@{
    ViewData["Title"] = "Home Page";
}

<div class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1 class="hero-title">Timeless Elegance</h1>
        <a href="#featured" class="btn btn-primary">Shop Now</a>
    </div>
</div>

<div class="container section-padding" id="featured">
    <div class="text-center mb-5">
        <h2>Featured Collection</h2>
        <p class="text-muted">Refined Simplicity.</p>
    </div>
    <div class="row">
        <!-- Placeholder Products -->
        @for (int i = 1; i <= 4; i++)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100">
                    <img src="https://images.unsplash.com/photo-1505022610485-0249ba5b3675?w=500&auto=format&fit=crop&q=60&ixlib=rb-4.0.3" class="card-img-top" alt="Product Image">
                    <div class="card-body text-center">
                        <h5 class="card-title">Classic Linen Shirt</h5>
                        <p class="card-text text-muted">$85.00</p>
                        <a href="#" class="btn btn-secondary btn-sm">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="bg-cream section-padding">
    <div class="container text-center">
        <h3 class="mb-4 text-gold">The Bervado Standard</h3>
        <p class="lead" style="max-width: 600px; margin: 0 auto;">
            BERVADO is an "Affordable Old Money" clothing brand focused on quiet elegance, minimalism, and timeless style. We avoid flashy elements and emphasize subtle luxury through design, color, and presentation.
        </p>
    </div>
</div>

<!-- Support Chat Floating Button -->
<div id="support-widget" style="position: fixed; bottom: 20px; right: 20px; z-index: 1050;">
    <button class="btn btn-primary rounded-circle" id="support-toggle" style="width: 60px; height: 60px; font-size: 24px;">💬</button>
    <div id="support-box" class="card d-none" style="position: absolute; bottom: 70px; right: 0; width: 300px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
        <div class="card-header bg-navy text-white" style="background-color: var(--navy); color: white;">
            Bervado Support
            <button type="button" class="btn-close btn-close-white float-end" id="support-close"></button>
        </div>
        <div class="card-body" id="support-messages" style="height: 250px; overflow-y: auto; font-size: 0.9rem;">
            <p class="text-muted small text-center">Chat started.</p>
        </div>
        <div class="card-footer">
            <div class="input-group">
                <input type="text" id="support-input" class="form-control" placeholder="Type a message...">
                <button class="btn btn-secondary" id="support-send">Send</button>
            </div>
        </div>
    </div>
</div>
