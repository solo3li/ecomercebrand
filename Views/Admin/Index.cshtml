@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="container section-padding">
    <h2>Admin Dashboard</h2>
    <hr />
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action active" style="background-color: var(--navy); border-color: var(--navy);">Dashboard</a>
                <a href="#" class="list-group-item list-group-item-action">Products</a>
                <a href="#" class="list-group-item list-group-item-action">Orders</a>
                <a href="#" class="list-group-item list-group-item-action">Users & Roles</a>
            </div>
        </div>
        <div class="col-md-9">
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Welcome Admin</h5>
                    <p class="card-text">Select an option from the menu to manage the store.</p>
                </div>
            </div>

            <!-- Admin Notifications Widget -->
            <div class="card">
                <div class="card-header" style="background-color: var(--olive); color: white;">
                    Real-time Support Notifications
                </div>
                <div class="card-body" id="admin-notifications" style="height: 200px; overflow-y: auto;">
                    <p class="text-muted small">Awaiting messages...</p>
                </div>
            </div>
        </div>
    </div>
</div>
