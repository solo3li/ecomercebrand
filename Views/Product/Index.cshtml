@model IEnumerable<Bervado.Web.Models.Product>

@{
    ViewData["Title"] = "Shop";
}

<div class="container section-padding">
    <div class="text-center mb-5">
        <h2>The Collection</h2>
        <p class="text-muted">Refined Simplicity.</p>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 350px; object-fit: cover;">
                    <div class="card-body text-center d-flex flex-column">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted mb-4">$@item.Price.ToString("0.00")</p>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-secondary mt-auto mx-auto">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
